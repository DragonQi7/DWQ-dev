# .env — Newsletter Sender Credentials
# ──────────────────────────────────────────────────────────────────
# NEVER commit this file to Git. It is already in .gitignore.
# Copy this file to .env and fill in your real values.
# ──────────────────────────────────────────────────────────────────

# ── SMTP Settings ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com

# Gmail users: use an App Password, NOT your real Gmail password.
# Create one at: https://myaccount.google.com/apppasswords
SMTP_PASS=xxxx xxxx xxxx xxxx

# ── Sender Identity ───────────────────────────────────────────────
FROM_NAME=Taoquen Wellness
FROM_EMAIL=you@gmail.com
REPLY_TO=you@gmail.com

# ── Other SMTP providers (uncomment and replace as needed) ────────
# Outlook/Hotmail:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#
# Zoho Mail:
#   SMTP_HOST=smtp.zoho.com
#   SMTP_PORT=587
#
# SendGrid (free up to 100/day):
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.your_sendgrid_api_key_here
